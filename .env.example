## Firebase Web App config (from Firebase Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

## Security (comma-separated emails)
VITE_ALLOWED_EMAILS=you@example.com

## Optional: Anthropic relay (server-side proxy for Claude API)
# VITE_AI_RELAY_URL=https://your-relay.example.com/anthropic

## Optional: Perplexity proxy for production (browser CORS bypass)
# VITE_PERPLEXITY_PROXY_URL=https://your-relay.example.com/perplexity

